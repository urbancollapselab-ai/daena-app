{
  "identifier": "daena-default",
  "description": "Daena AI Command Center permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "python",
          "cmd": "python3",
          "args": true
        },
        {
          "name": "claude",
          "cmd": "claude",
          "args": true
        },
        {
          "name": "node",
          "cmd": "node",
          "args": true
        },
        {
          "name": "npm",
          "cmd": "npm",
          "args": true
        }
      ]
    },
    "shell:allow-spawn",
    "notification:default",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission",
    "notification:allow-notify",
    "store:default",
    "os:default",
    "process:default",
    "process:allow-exit",
    "process:allow-restart"
  ]
}
